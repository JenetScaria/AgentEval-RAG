# ── Copy this file to .env and fill in your values ────────────────────────────

# Gemini (required — free tier at aistudio.google.com)
GEMINI_API_KEY=your_API_KEY_here

# Tavily web search (optional — DuckDuckGo is used as free fallback)
TAVILY_API_KEY=your_tavily_api_key_here

# Model (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Retrieval tuning
# TOP_K_RETRIEVAL=10
# TOP_K_RERANK=5
# CHUNK_SIZE=512
# CHUNK_OVERLAP=50

# Eval thresholds (0–1)
# FAITHFULNESS_THRESHOLD=0.7
# CONTEXT_PRECISION_THRESHOLD=0.7
# ANSWER_RELEVANCY_THRESHOLD=0.7
# MAX_RETRIES=2

# MLflow
# MLFLOW_TRACKING_URI=mlruns
# MLFLOW_EXPERIMENT_NAME=agenteval_rag
